{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Banana ID",
  "colors": {
    "primary": "#E6A817",
    "light": "#F0BB4A",
    "dark": "#CE9512"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "mailto:suporte@banana-id.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://banana-id.lovable.app"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Início",
        "pages": ["index", "quickstart", "autenticacao", "sandbox", "uso-com-ia"]
      },
      {
        "group": "Blocos de validação",
        "pages": [
          "blocos/cpf",
          "blocos/otp",
          "blocos/documento",
          "blocos/face"
        ]
      },
      {
        "group": "Referência",
        "pages": [
          "referencia/objeto-verificacao",
          "referencia/reasons",
          "referencia/erros",
          "referencia/polling"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://banana-id.lovable.app",
          "icon": "gauge"
        },
        {
          "anchor": "Status",
          "href": "https://status.banana-id.com",
          "icon": "signal"
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/banana-id"
    }
  }
}
